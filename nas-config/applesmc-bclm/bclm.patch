+
+/*
+ * Battery charge limit.
+ *
+ * The SMC "BCLM" key ("Battery Charge Level Max") is a ui8 percentage that caps
+ * how full the battery charges; this is the same lever macOS battery-management
+ * tools (bclm/AlDente) use. Mainline applesmc exposes SMC keys read-only, so this
+ * adds the standard power_supply "charge_control_end_threshold" sysfs attribute on
+ * the battery and wires it to BCLM, e.g.:
+ *
+ *	echo 80 > /sys/class/power_supply/BAT0/charge_control_end_threshold
+ *
+ * We attach via the ACPI battery hook (battery_hook_register), which replays for
+ * batteries that already registered before this module loaded, so it works
+ * regardless of load order. It is a no-op on Macs without the BCLM key.
+ */
+#define CHARGE_LIMIT_KEY "BCLM"
+
+static bool applesmc_has_charge_limit;
+
+static ssize_t charge_control_end_threshold_show(struct device *dev,
+		struct device_attribute *attr, char *buf)
+{
+	u8 val;
+	int ret;
 
+	ret = applesmc_read_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return sysfs_emit(buf, "%u\n", val);
+}
+
+static ssize_t charge_control_end_threshold_store(struct device *dev,
+		struct device_attribute *attr, const char *buf, size_t count)
+{
+	u8 val;
+	int ret;
+
+	ret = kstrtou8(buf, 10, &val);
+	if (ret)
+		return ret;
+	/* Refuse nonsensical caps; a too-low ceiling could leave the pack empty. */
+	if (val < 10 || val > 100)
+		return -EINVAL;
+
+	ret = applesmc_write_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return count;
+}
+
+static DEVICE_ATTR_RW(charge_control_end_threshold);
+
+static int applesmc_battery_add(struct power_supply *battery,
+		struct acpi_battery_hook *hook)
+{
+	return device_create_file(&battery->dev,
+				  &dev_attr_charge_control_end_threshold);
+}
+
+static int applesmc_battery_remove(struct power_supply *battery,
+		struct acpi_battery_hook *hook)
+{
+	device_remove_file(&battery->dev,
+			   &dev_attr_charge_control_end_threshold);
+	return 0;
+}
+
+static struct acpi_battery_hook applesmc_battery_hook = {
+	.add_battery = applesmc_battery_add,
+	.remove_battery = applesmc_battery_remove,
+	.name = "applesmc battery charge limit",
+};
+
 static int __init applesmc_init(void)
 {
 	int ret;
@@ -1368,6 +1442,11 @@
