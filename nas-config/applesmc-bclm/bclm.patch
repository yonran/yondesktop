--- a/applesmc.c	2026-06-20 15:47:47
+++ b/applesmc.c	2026-06-20 17:19:05
@@ -1306,6 +1306,60 @@
 	{ .ident = NULL }
 };
 
+/*
+ * Battery charge limit.
+ *
+ * The SMC "BCLM" key ("Battery Charge Level Max") is a ui8 percentage that caps
+ * how full the battery charges; this is the same lever macOS battery-management
+ * tools (bclm/AlDente) use. Mainline applesmc exposes SMC keys read-only, so this
+ * adds a charge_control_end_threshold attribute wired to BCLM, e.g.:
+ *
+ *	echo 80 > /sys/devices/platform/applesmc.768/charge_control_end_threshold
+ *
+ * The attribute lives on applesmc's own platform device rather than on the battery
+ * power_supply: on these Macs BAT0 is a Smart Battery (ACPI0002, owned by sbs.ko),
+ * and mainline sbs has no battery-hook API to attach to (only the control-method
+ * battery.c does). Writing BCLM is a pure SMC operation, independent of how the
+ * battery is read, so the platform-device location works regardless. It is created
+ * only on Macs that actually have the BCLM key.
+ */
+#define CHARGE_LIMIT_KEY "BCLM"
+
+static bool applesmc_has_charge_limit;
+
+static ssize_t charge_control_end_threshold_show(struct device *dev,
+		struct device_attribute *attr, char *buf)
+{
+	u8 val;
+	int ret;
+
+	ret = applesmc_read_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return sysfs_emit(buf, "%u\n", val);
+}
+
+static ssize_t charge_control_end_threshold_store(struct device *dev,
+		struct device_attribute *attr, const char *buf, size_t count)
+{
+	u8 val;
+	int ret;
+
+	ret = kstrtou8(buf, 10, &val);
+	if (ret)
+		return ret;
+	/* Refuse nonsensical caps; a too-low ceiling could leave the pack empty. */
+	if (val < 10 || val > 100)
+		return -EINVAL;
+
+	ret = applesmc_write_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return count;
+}
+
+static DEVICE_ATTR_RW(charge_control_end_threshold);
+
 static int __init applesmc_init(void)
 {
 	int ret;
@@ -1368,6 +1422,12 @@
 		goto out_light_ledclass;
 	}
 
+	/* Expose charge_control_end_threshold (BCLM) only if this Mac has the key. */
+	if (!applesmc_has_key(CHARGE_LIMIT_KEY, &applesmc_has_charge_limit) &&
+	    applesmc_has_charge_limit)
+		device_create_file(&pdev->dev,
+				   &dev_attr_charge_control_end_threshold);
+
 	return 0;
 
 out_light_ledclass:
@@ -1397,6 +1457,9 @@
 
 static void __exit applesmc_exit(void)
 {
+	if (applesmc_has_charge_limit)
+		device_remove_file(&pdev->dev,
+				   &dev_attr_charge_control_end_threshold);
 	hwmon_device_unregister(hwmon_dev);
 	applesmc_release_key_backlight();
 	applesmc_release_light_sensor();
