+/*
+ * Battery charge limit.
+ *
+ * The SMC "BCLM" key ("Battery Charge Level Max") is a ui8 percentage that caps
+ * how full the battery charges; this is the same lever macOS battery-management
+ * tools (bclm/AlDente) use. Mainline applesmc exposes SMC keys read-only, so this
+ * adds the standard power_supply charge_control_end_threshold attribute, e.g.:
+ *
+ *	echo 80 > /sys/class/power_supply/BAT0/charge_control_end_threshold
+ *
+ * On these Macs BAT0 is a Smart Battery (ACPI0002, owned by sbs.ko), and mainline
+ * sbs has no battery-hook API (only the control-method battery.c exports
+ * battery_hook_register). Rather than fork sbs (what applesmc-next does, which oopses
+ * on some Macs), we look the battery up by name and create the attribute on its
+ * power_supply device, so it appears at the standard location that tools (TLP,
+ * upower, ...) expect. A power_supply notifier handles the battery registering after
+ * applesmc loads. Writing BCLM is a pure SMC op, independent of how the battery is
+ * read. No-op on Macs without the BCLM key.
+ */
+#define CHARGE_LIMIT_KEY "BCLM"
+
+static bool applesmc_has_charge_limit;
+
+static ssize_t charge_control_end_threshold_show(struct device *dev,
+		struct device_attribute *attr, char *buf)
+{
+	u8 val;
+	int ret;
 
+	ret = applesmc_read_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return sysfs_emit(buf, "%u\n", val);
+}
+
+static ssize_t charge_control_end_threshold_store(struct device *dev,
+		struct device_attribute *attr, const char *buf, size_t count)
+{
+	u8 val;
+	int ret;
+
+	ret = kstrtou8(buf, 10, &val);
+	if (ret)
+		return ret;
+	/* Refuse nonsensical caps; a too-low ceiling could leave the pack empty. */
+	if (val < 10 || val > 100)
+		return -EINVAL;
+
+	ret = applesmc_write_key(CHARGE_LIMIT_KEY, &val, 1);
+	if (ret)
+		return ret;
+	return count;
+}
+
+static DEVICE_ATTR_RW(charge_control_end_threshold);
+
+static DEFINE_MUTEX(applesmc_battery_lock);
+static struct power_supply *applesmc_battery;	/* held ref while the attr exists */
+
+/* Create charge_control_end_threshold on BAT0's power_supply device. Idempotent. */
+static void applesmc_attach_battery(void)
+{
+	struct power_supply *psy;
+
+	mutex_lock(&applesmc_battery_lock);
+	if (applesmc_battery)
+		goto out;			/* already attached */
+	psy = power_supply_get_by_name("BAT0");
+	if (!psy)
+		goto out;			/* not present yet; notifier will retry */
+	if (device_create_file(&psy->dev, &dev_attr_charge_control_end_threshold)) {
+		power_supply_put(psy);
+		goto out;
+	}
+	applesmc_battery = psy;			/* keep the ref while the attr is live */
+out:
+	mutex_unlock(&applesmc_battery_lock);
+}
+
+static void applesmc_detach_battery(void)
+{
+	mutex_lock(&applesmc_battery_lock);
+	if (applesmc_battery) {
+		device_remove_file(&applesmc_battery->dev,
+				   &dev_attr_charge_control_end_threshold);
+		power_supply_put(applesmc_battery);
+		applesmc_battery = NULL;
+	}
+	mutex_unlock(&applesmc_battery_lock);
+}
+
+/* Only PSY_EVENT_PROP_CHANGED exists; any battery activity is our cue to (re)try
+ * attaching if we haven't managed to yet. attach is a no-op once done. */
+static int applesmc_psy_notify(struct notifier_block *nb, unsigned long event,
+			       void *data)
+{
+	applesmc_attach_battery();
+	return NOTIFY_OK;
+}
+
+static struct notifier_block applesmc_psy_nb = {
+	.notifier_call = applesmc_psy_notify,
+};
+
 static int __init applesmc_init(void)
 {
 	int ret;
